#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_RUNTIME_DIR="${CODEX_RUNTIME_NODE_DIR:-$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/node}"
NODE_BIN="${NODE_BIN:-$DEFAULT_RUNTIME_DIR/bin/node}"
NODE_MODULES="${NODE_MODULES:-$DEFAULT_RUNTIME_DIR/node_modules}"

if [[ ! -x "$NODE_BIN" ]]; then
  if command -v node >/dev/null 2>&1; then
    NODE_BIN="$(command -v node)"
  else
    echo "Node.js not found. Set NODE_BIN or install Node.js." >&2
    exit 1
  fi
fi

if [[ -d "$NODE_MODULES" ]]; then
  NODE_PATH="$NODE_MODULES${NODE_PATH:+:$NODE_PATH}" "$NODE_BIN" "$ROOT_DIR/scripts/register-team-account.mjs" "$@"
else
  "$NODE_BIN" "$ROOT_DIR/scripts/register-team-account.mjs" "$@"
fi
